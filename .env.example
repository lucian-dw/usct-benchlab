USCT_WORKSPACE=$HOME/usct-benchlab
USCT_DATA_ROOT=$USCT_WORKSPACE/data/openbreastus
USCT_RUN_ROOT=$USCT_WORKSPACE/runs/usctbench_runs

USCT_NBP_ZIP_PATH=/path/to/NBPslices2D.zip
USCT_KWAVE_FWI_RESULT_PATH=/path/to/fwi_result.mat
USCT_KWAVE_ROOT=/path/to/external/USCT_kwave
USCT_KWAVE_PYTHON_BIN=/path/to/python
USCT_DPS_FWI_RESULT_PATH=/path/to/dps_result.mat
USCT_DPS_FWI_SUMMARY_PATH=/path/to/dps_result.json
USCT_DPS_DATASET_PATH=/path/to/kwave_dataset.mat
USCT_DPS_CHECKPOINT=/path/to/diffusion_checkpoint.pth
USCT_DPS_FWI_LOG_PATH=$USCT_RUN_ROOT/dps_fwi.log

USCT_SYNTHETIC_CASE_GLOB=$USCT_WORKSPACE/data/synthetic_demo/cases/*.h5
USCT_NBP_CASE_GLOB=$USCT_WORKSPACE/data/nbpslice2d_demo/cases/*.h5
USCT_OPENBREASTUS_CASE_GLOB=$USCT_WORKSPACE/data/openbreastus_demo/cases/*.h5
USCT_KWAVE_FWI_CASE_GLOB=$USCT_WORKSPACE/data/fwi_kwave_demo/cases/*.h5
USCT_DPS_FWI_CASE_GLOB=$USCT_WORKSPACE/data/fwi_kwave_demo/cases/*.h5
